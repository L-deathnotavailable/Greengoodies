<header class="header">
  <nav class="nav">
    <a class="brand" href="{{ path('app_home') }}">
      <img src="{{ asset('img/logo-title.png') }}" alt="Green Goodies" class="logo">
    </a>

    <div class="links">
      <a href="{{ path('app_product_index') }}" class="link">Nos produits</a> 
      <a href="{{ path('app_cart') }}" class="link">Mon panier</a>

      {% if app.user %}
        <a href="{{ path('app_account') }}" class="link">Mon compte</a>
        <a href="{{ path('app_logout') }}" class="link">Déconnexion</a>
      {% else %}
        <a href="{{ path('app_login') }}" class="link">Connexion</a>
        <a href="{{ path('app_register') }}" class="link">Inscription</a>
      {% endif %}
    </div>
  </nav>
</header>
